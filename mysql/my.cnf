[mysqld]
# Character set
character-set-server  = utf8mb4
collation-server      = utf8mb4_unicode_ci

# Performance
innodb_buffer_pool_size    = 256M     # tune to ~70% of available RAM
innodb_log_file_size       = 64M
innodb_flush_log_at_trx_commit = 2   # slight durability tradeoff for speed
innodb_flush_method        = O_DIRECT
max_connections            = 150
query_cache_type           = 0       # query cache is deprecated in MySQL 8
thread_cache_size          = 16
table_open_cache           = 400
join_buffer_size           = 256K
sort_buffer_size           = 256K

# Slow query logging (great for finding missing indexes)
slow_query_log             = 1
slow_query_log_file        = /var/log/mysql/slow.log
long_query_time            = 1

# Security
local_infile               = 0

[client]
default-character-set = utf8mb4
