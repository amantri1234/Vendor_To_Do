# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite for local dev; switch to MySQL in production
DATABASE_URL=sqlite:///./taskflow.db

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=dev-secret-key-do-not-use-in-production-change-me-32chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
