# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=true
# Set to false in production — disables /docs and /redoc

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=mysql+pymysql://todouser:todopassword@localhost:3306/todoapp

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-replace-this-with-a-real-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ──────────────────────────────────────────────────────────────────────
# In production, set this to your actual frontend domain, e.g.:
# CORS_ORIGINS=["https://yourdomain.com"]
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
